{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@stint/core": ["../../packages/core/src/index.ts"],
      "@stint/core/*": ["../../packages/core/src/*"],
      "@stint/data": ["../../packages/data/src/index.ts"],
      "@stint/data/*": ["../../packages/data/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
