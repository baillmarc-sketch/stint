# --- Stint environment variables ---
# The demo runs WITHOUT any of these (it renders from the in-repo NYC dataset).
# Add them to enable real Google SSO and, later, Supabase-backed bookings.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER prefix with NEXT_PUBLIC. Used by the seed script + privileged routes.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for OAuth redirects + OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Marketplace economics (shown as a checkout line item)
NEXT_PUBLIC_SERVICE_FEE_PCT=0.12

# Payments provider: "simulated" (default) | "stripe" (real test-mode payments)
PAYMENTS_PROVIDER=simulated

# Stripe Connect (test mode) — only needed when PAYMENTS_PROVIDER=stripe.
# Dashboard → Developers → API keys. Enable Connect (Express) first.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (Developers → Webhooks, or `stripe listen`).
# Send payment_intent.* and account.updated → /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# Google OAuth is configured in the Supabase dashboard (Auth → Providers → Google),
# with the authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
